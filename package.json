{
  "name": "devagent",
  "version": "1.0.0",
  "description": "AI Agent REST API with tool calling (Express + TypeScript + OpenAI)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--experimental-sqlite tsx watch src/server.ts",
    "build": "tsc",
    "start": "node --experimental-sqlite dist/server.js",
    "seed": "cross-env NODE_OPTIONS=--experimental-sqlite tsx src/db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "tool-calling",
    "openai",
    "express"
  ],
  "license": "MIT",
  "dependencies": {
    "@tavily/core": "^0.5.11",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "mathjs": "^14.5.2",
    "openai": "^4.104.0",
    "pino": "^9.7.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.32",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
